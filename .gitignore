# =============================================================
# Ordre — .gitignore
# =============================================================

# ---------- Dependencies ----------
node_modules/
jspm_packages/
bower_components/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnpm-store/

# ---------- Build output ----------
dist/
dist-ssr/
build/
out/
.next/
.nuxt/
.turbo/
.svelte-kit/

# ---------- Environment & secrets ----------
# Never commit anything with real secrets.
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example
!.env.*.example

# Firebase admin service account keys — these authenticate server-side.
firebase-admin-key*.json
service-account*.json
serviceAccountKey*.json
*-firebase-adminsdk-*.json

# Auth tokens / credentials
*.pem
*.key
*.p12
*.keystore

# ---------- Firebase ----------
.firebase/
.firebaserc.local
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
database-debug.log*
pubsub-debug.log*

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm/

# ---------- Caches ----------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.vite/
.vitest-reports/
.rollup.cache/
.swc/

# ---------- TypeScript ----------
*.tsbuildinfo
.tsimp/

# ---------- Testing / coverage ----------
coverage/
.nyc_output/
lib-cov/
*.lcov

# ---------- Editor / IDE ----------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
.project
.classpath
.factorypath
.settings/

# ---------- OS cruft ----------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Misc ----------
*.bak
*.tmp
*.temp
*.orig
*.rej
