# Firebase web-app config (safe to embed in the client, but sourced from env for environment parity).
# Duplicate this file to .env.local and fill in.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# PostHog project API key (EU cloud). Create a project at
# https://eu.posthog.com/ and paste the "Project API Key" value here.
# PostHog handles product analytics + exception capture; it only loads
# after the user accepts the analytics category in the consent banner.
VITE_POSTHOG_KEY=
# Override the default PostHog host if you're self-hosting. Defaults to
# the EU cloud (https://eu.i.posthog.com).
VITE_POSTHOG_HOST=

# Flip on when Stripe self-serve billing ships. Free-only launches leave
# this unset so the "Upgrade" header CTA and self-serve checkout are
# hidden; Pro is granted manually via `npm run grant-pro` during beta.
VITE_BILLING_ENABLED=

# Firebase App Check — reCAPTCHA v3 site key. Create one in the Firebase
# console → App Check → Apps → Web (reCAPTCHA v3). Without this the client
# cannot reach Firestore / Storage / Functions when enforcement is on.
VITE_FIREBASE_APP_CHECK_SITE_KEY=

# Local-only App Check debug token. Register the token in the Firebase
# console under App Check → Apps → Manage debug tokens, then paste it
# here. Alternatively set VITE_APP_CHECK_DEBUG=true to let the SDK print
# a fresh debug token on first page load (copy it into the console).
VITE_APP_CHECK_DEBUG_TOKEN=
VITE_APP_CHECK_DEBUG=

# Seed script (node-side, uses firebase-admin).
# Service-account JSON downloaded from Firebase console → Project settings → Service accounts.
FIREBASE_ADMIN_KEY_PATH=./firebase-admin-key.json
SEED_OWNER_UID=

# Stripe — all keys are server-side only (Cloud Functions secrets).
# Set them via: firebase functions:secrets:set STRIPE_SECRET_KEY
# For local dev, create functions/.secret.local with:
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...   (from: stripe listen --forward-to ...)
#   STRIPE_PRICE_MONTHLY=price_...
#   STRIPE_PRICE_ANNUAL=price_...
