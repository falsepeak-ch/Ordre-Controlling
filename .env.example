# Firebase web-app config (safe to embed in the client, but sourced from env for environment parity).
# Duplicate this file to .env.local and fill in.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Seed script (node-side, uses firebase-admin).
# Service-account JSON downloaded from Firebase console → Project settings → Service accounts.
FIREBASE_ADMIN_KEY_PATH=./firebase-admin-key.json
SEED_OWNER_UID=

# RevenueCat Web Billing public API key (client-side).
# Entitlement ID must match the one configured in the RevenueCat dashboard.
VITE_REVENUECAT_PUBLIC_API_KEY=
VITE_REVENUECAT_ENTITLEMENT_ID=Ordre Pro
