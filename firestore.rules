rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function projectRole(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data.members[request.auth.uid];
    }

    function isProjectMember(projectId) {
      return isSignedIn() && projectRole(projectId) != null;
    }

    function canWriteProject(projectId) {
      return isSignedIn() &&
        (projectRole(projectId) == 'owner' || projectRole(projectId) == 'editor');
    }

    function canApproveProject(projectId) {
      return isSignedIn() &&
        (projectRole(projectId) == 'owner' || projectRole(projectId) == 'approver');
    }

    function isProjectOwner(projectId) {
      return isSignedIn() && projectRole(projectId) == 'owner';
    }

    // ---------- Users ----------
    // A signed-in user can always read/write their own doc, EXCEPT for
    // Stripe subscription fields which are managed exclusively by Cloud
    // Functions (admin SDK) to prevent client-side entitlement spoofing.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid) &&
        !('subscriptionStatus' in request.resource.data) &&
        !('subscriptionId' in request.resource.data) &&
        !('stripeCustomerId' in request.resource.data) &&
        !('subscriptionPlan' in request.resource.data) &&
        !('subscriptionCurrentPeriodEnd' in request.resource.data);
      allow update: if isSelf(uid) &&
        request.resource.data.subscriptionStatus == resource.data.subscriptionStatus &&
        request.resource.data.subscriptionId == resource.data.subscriptionId &&
        request.resource.data.subscriptionPlan == resource.data.subscriptionPlan &&
        request.resource.data.subscriptionCurrentPeriodEnd == resource.data.subscriptionCurrentPeriodEnd &&
        request.resource.data.stripeCustomerId == resource.data.stripeCustomerId;
      allow delete: if false;
    }

    // Rate-limit counters. Writable only by admin-SDK Cloud Functions;
    // clients must not inspect or tamper with them.
    match /rateLimits/{path=**} {
      allow read, write: if false;
    }

    // ---------- Projects ----------
    match /projects/{projectId} {
      // Read: only members.
      allow read: if isSignedIn() && resource.data.members[request.auth.uid] != null;

      // Create: disabled from the client. All project creation flows
      // through the `createProject` Cloud Function (admin SDK), which
      // enforces the free-tier project-count quota. Direct client-side
      // creates would bypass that quota.
      allow create: if false;

      // Update content (name, description, initial, etc.) while leaving
      // the members map untouched — any editor/owner may do this.
      // Changing the members map or the memberEmails/memberProfiles maps
      // is owner-only. Additionally, `storageBytesUsed` and
      // `storageCapBytes` are maintained by Cloud Functions only.
      allow update: if isSignedIn() && (
        (
          canWriteProject(projectId) &&
          request.resource.data.members == resource.data.members &&
          request.resource.data.storageBytesUsed == resource.data.storageBytesUsed &&
          request.resource.data.storageCapBytes == resource.data.storageCapBytes
        ) ||
        (
          isProjectOwner(projectId) &&
          request.resource.data.storageBytesUsed == resource.data.storageBytesUsed &&
          request.resource.data.storageCapBytes == resource.data.storageCapBytes
        )
      );

      // Delete: owner only.
      allow delete: if isProjectOwner(projectId);

      // ---- Project sub-collections ----
      match /suppliers/{id} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if canWriteProject(projectId);

        match /docs/{docId} {
          allow read: if isProjectMember(projectId);
          allow create, update, delete: if canWriteProject(projectId);
        }
      }

      match /categories/{id} {
        allow read: if isProjectMember(projectId);
        allow create, update, delete: if canWriteProject(projectId);
      }

      // Project-level counters (PO numbering, …). Editors and owners
      // may mutate; nothing here is user-visible on its own. Kept as a
      // distinct branch so the other subcollections' rules stay tight.
      match /meta/{docId} {
        allow read: if isProjectMember(projectId);
        allow create, update: if canWriteProject(projectId);
        allow delete: if isProjectOwner(projectId);
      }

      match /purchaseOrders/{poId} {
        allow read: if isProjectMember(projectId);
        // Editors/owners CRUD POs fully. Approvers may update a PO's
        // status/closedAt/approvedAt as part of recording spend; the
        // client does this atomically with invoice + approval writes.
        allow create, delete: if canWriteProject(projectId);
        allow update: if canWriteProject(projectId) || canApproveProject(projectId);

        match /invoices/{invId} {
          allow read: if isProjectMember(projectId);
          // Editors/owners can always write invoices. Approvers can
          // create invoices as part of the approve-with-bill flow.
          allow create: if canWriteProject(projectId) || canApproveProject(projectId);
          allow update, delete: if canWriteProject(projectId);
        }

        match /approvals/{apId} {
          allow read: if isProjectMember(projectId);
          // Approvers and owners append approval-log entries.
          allow create: if canApproveProject(projectId);
          // Approval-log is append-only for audit purposes; only owners
          // may clean up (e.g. re-open a rejected PO).
          allow update, delete: if isProjectOwner(projectId);
        }

        match /attachments/{attId} {
          allow read: if isProjectMember(projectId);
          allow create, update, delete: if canWriteProject(projectId);
        }
      }
    }
  }
}
